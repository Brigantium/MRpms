library(MRpms)
library(devtools)
load_all()
# Ejemplo 1: dos senos a distintas alturas
{set.seed(2026)
x1 <- 10*runif(100)
m1 <- sin(x1) + 0.3*rnorm(100)
x2 <- 10*runif(100)
m2 <- sin(x2) + 0.3*rnorm(100) - 3
X <- c(x1, x2)
Y <- c(m1, m2)
muestra <- cbind(X, Y)
plot(X, Y)}
ConfPMS(muestra, B = 10)
ConfPMS(X = X, Y = Y, B = 10)
load_all()
ConfPMS(muestra, B = 10)
use_readme_rmd()
install.packages('https://github.com/Brigantium/MRpms/archive/refs/heads/main.zip', repos = NULL, INSTALL_opts = "--with-keep.source")
build_readme()
remotes::install_github(Brigantium/MRpms)
remotes::install_github("Brigantium/MRpms")
detach(MRpms)
detach("MRpms"")
)
detach("MRpms")
remotes::install_github("Brigantium/RMpms")
remotes::install_github("Brigantium/MRpms")
build_readme()
library(devtools)
build_readme()
